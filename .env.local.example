# ============================================================
# SaaSMatch — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to version control.
#
# Find these in your Supabase project:
#   Settings → API → Project URL / Project API keys
# ============================================================

# Supabase project URL (e.g. https://xyzabc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase anon key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service-role key — NEVER expose to the browser.
# Used only in server-side code (Server Actions, Route Handlers, Middleware).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
